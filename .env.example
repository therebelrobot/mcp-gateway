# Environment Variables for MCP Gateway
# Copy this file to .env and fill in your values

# Brave Search API Key (https://brave.com/search/api/)
BRAVE_API_KEY=your_brave_api_key_here

# EMQX MQTT Broker Credentials
EMQX_API_URL=https://your-emqx-cloud-instance.com:8443/api/v5
EMQX_API_KEY=your_emqx_api_key_here
EMQX_API_SECRET=your_emqx_api_secret_here

# OpenAI API Key (for LibreChat)
OPENAI_API_KEY=your_openai_api_key_here

# Other MCP Server Environment Variables
# Add any other environment variables required by your MCP servers here

# Docker socket path (optional, only needed for Docker-based MCP servers)
# DOCKER_HOST=unix:///var/run/docker.sock

# Log level for Supergateway (debug, info, none)
# LOG_LEVEL=info

# Base URL for SSE endpoints (used internally)
# BASE_URL=http://localhost